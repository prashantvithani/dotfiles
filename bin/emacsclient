#!/bin/bash

# EMACS="$HOME/Workspace/repos/emacs/nextstep/Emacs.app/Contents/MacOS/Emacs"

if [[ "$EMACS_VERSION" = "30" ]]; then
    EMACS="$HOME/Workspace/repos/emacs-30/lib-src/emacsclient"
else
    EMACS="$HOME/Workspace/repos/emacs/lib-src/emacsclient"
fi

# EMACS="/usr/bin/emacs"
exec "$EMACS" "$@"
